{
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/index.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/OurTeam.html",
      "destination": "/OurTeam",
      "permanent": true
    },
    {
      "source": "/Download.html",
      "destination": "/Download",
      "permanent": true
    },
    {
      "source": "/download.html",
      "destination": "/Download",
      "permanent": true
    },
    {
      "source": "/settings.html",
      "destination": "/settings",
      "permanent": true
    },
    {
      "source": "/rating.html",
      "destination": "/rating",
      "permanent": true
    },
    {
      "source": "/idle.html",
      "destination": "/idle",
      "permanent": true
    },
    {
      "source": "/team's-work.html",
      "destination": "/teams-work",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "/Website/index.html"
    },
    {
      "source": "/OurTeam",
      "destination": "/Website/OurTeam.html"
    },
    {
      "source": "/our-team",
      "destination": "/Website/OurTeam.html"
    },
    {
      "source": "/Download",
      "destination": "/Website/Download.html"
    },
    {
      "source": "/download",
      "destination": "/Website/Download.html"
    },
    {
      "source": "/settings",
      "destination": "/Website/settings.html"
    },
    {
      "source": "/rating",
      "destination": "/Website/rating.html"
    },
    {
      "source": "/idle",
      "destination": "/Website/idle.html"
    },
    {
      "source": "/teams-work",
      "destination": "/Website/team's-work.html"
    },
    {
      "source": "/styles.css",
      "destination": "/Website/styles.css"
    },
    {
      "source": "/scripts.js",
      "destination": "/Website/scripts.js"
    },
    {
      "source": "/animations.js",
      "destination": "/Website/animations.js"
    },
    {
      "source": "/ads.txt",
      "destination": "/Website/ads.txt"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/Website/sitemap.xml"
    },
    {
      "source": "/images/:path*",
      "destination": "/Website/images/:path*"
    },
    {
      "source": "/fonts/:path*",
      "destination": "/Website/fonts/:path*"
    },
    {
      "source": "/Download/:path*",
      "destination": "/Website/Download/:path*"
    },
    {
      "source": "/Minigames/:path*",
      "destination": "/Website/Minigames/:path*"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "index, follow"
        }
      ]
    }
  ]
}

